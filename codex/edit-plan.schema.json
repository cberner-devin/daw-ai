{
  "type": "object",
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "musicalPlan": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "object",
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["gain", "mute", "midi-clip", "add-track", "instrument", "modulator", "configure", "effect", "remove-effect", "filter", "rhythm", "tempo"]
          },
          "target": {
            "type": "string",
            "enum": ["all", "drums", "bass", "chords", "lead", "texture"]
          },
          "name": {
            "type": "string",
            "anyOf": [
              {
                "enum": ["None", "MIDI Clip", "sine", "triangle", "sawtooth", "square", "instrument.attack", "instrument.release", "instrument.tone", "instrument.pitch", "track.volume", "Reverb", "Room", "Echo", "Chorus", "Low-pass filter", "Punch compressor", "Shimmer", "Effects"]
              },
              {
                "pattern": "^effect:[1-9][0-9]*\\.mix$"
              }
            ]
          },
          "value": {
            "type": "number"
          },
          "trackId": {
            "type": "integer",
            "minimum": 0
          },
          "tool": {
            "type": "string",
            "enum": ["None", "instrument", "effect", "modulator", "event", "routing"]
          },
          "toolId": {
            "type": "integer",
            "minimum": 0
          },
          "clipId": {
            "type": "integer",
            "minimum": 0
          },
          "parameter": {
            "type": "string",
            "enum": ["None", "waveform", "attack", "release", "tone", "mix", "enabled", "shape", "rate", "depth", "target", "time", "duration", "pitch", "velocity", "position"]
          },
          "setting": {
            "type": "string",
            "maxLength": 64
          },
          "start": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "end": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "rate": {
            "type": "number",
            "minimum": 0
          },
          "events": {
            "type": "array",
            "maxItems": 32,
            "items": {
              "type": "object",
              "properties": {
                "time": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 16
                },
                "duration": {
                  "type": "number",
                  "minimum": 0.0625,
                  "maximum": 16,
                  "description": "Duration in beats. It must not exceed the enclosing MIDI clip action's value (loop length); the server enforces this cross-field constraint."
                },
                "pitch": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 127
                },
                "velocity": {
                  "type": "number",
                  "minimum": 0.01,
                  "maximum": 1
                }
              },
              "required": ["time", "duration", "pitch", "velocity"],
              "additionalProperties": false
            }
          }
        },
        "required": ["kind", "target", "name", "value", "trackId", "tool", "toolId", "clipId", "parameter", "setting", "start", "end", "rate", "events"],
        "additionalProperties": false
      }
    }
  },
  "required": ["summary", "musicalPlan", "actions"],
  "additionalProperties": false
}
