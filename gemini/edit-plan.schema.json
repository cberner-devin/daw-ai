{
  "type": "object",
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "musicalPlan": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 9,
      "items": {
        "type": "object",
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["gain", "mute", "midi-clip", "add-track", "instrument", "modulator", "configure", "automation", "effect", "remove-effect", "filter", "rhythm", "tempo"]
          },
          "target": {
            "type": "string",
            "enum": ["all", "drums", "bass", "chords", "lead", "texture"]
          },
          "name": {
            "type": "string",
            "anyOf": [
              {
                "enum": ["None", "MIDI Clip", "Init", "Surge Percussion", "Surge Bass", "Surge Pad", "Surge Lead", "Surge Atmosphere", "instrument.attack", "instrument.release", "instrument.cutoff", "instrument.resonance", "instrument.pitch", "track.volume", "Reverb", "Room", "Echo", "Chorus", "Low-pass filter", "Punch compressor", "Drive", "Shimmer", "Effects"]
              },
              {
                "pattern": "^effect:[1-9][0-9]*\\.(mix|cutoff|resonance)$"
              },
              {
                "pattern": "^modulator:[1-9][0-9]*\\.(rate|depth)$"
              }
            ]
          },
          "value": {
            "type": "number",
            "description": "Primary numeric value. For configure actions, put numeric parameter values here; use 0 when setting carries a textual parameter value."
          },
          "trackId": {
            "type": "integer",
            "minimum": 0,
            "description": "Stable owning track ID for configure and automation actions; automation requires a nonzero ID."
          },
          "tool": {
            "type": "string",
            "enum": ["None", "instrument", "effect", "modulator", "event", "routing"]
          },
          "toolId": {
            "type": "integer",
            "minimum": 0
          },
          "clipId": {
            "type": "integer",
            "minimum": 0
          },
          "parameter": {
            "type": "string",
            "enum": ["None", "preset", "attack", "release", "cutoff", "resonance", "pitch", "mix", "enabled", "shape", "rate", "rateMode", "trigger", "depth", "target", "time", "duration", "velocity", "position"]
          },
          "setting": {
            "type": "string",
            "maxLength": 64,
            "description": "Text value for configure parameters such as preset, enabled, shape, rateMode, trigger, or target. Numeric configure parameters may use this string for compatibility but should normally use value."
          },
          "start": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Relative start within the selected region. Used by MIDI clips and time-bounded arrangement, mix, effect, and automation actions."
          },
          "end": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Relative end within the selected region; it must be after start."
          },
          "rate": {
            "type": "number",
            "minimum": 0
          },
          "events": {
            "type": "array",
            "maxItems": 32,
            "items": {
              "type": "object",
              "properties": {
                "time": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 16
                },
                "duration": {
                  "type": "number",
                  "minimum": 0.0625,
                  "maximum": 16,
                  "description": "Duration in beats. It must not exceed the enclosing MIDI clip action's value (loop length); the server enforces this cross-field constraint."
                },
                "pitch": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 127
                },
                "velocity": {
                  "type": "number",
                  "minimum": 0.01,
                  "maximum": 1
                }
              },
              "required": ["time", "duration", "pitch", "velocity"],
              "additionalProperties": false
            }
          },
          "points": {
            "type": "array",
            "minItems": 2,
            "maxItems": 16,
            "description": "Automation points with strictly increasing relative times from 0 through 1 and values in the selected automation target's published range.",
            "items": {
              "type": "object",
              "properties": {
                "time": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                "value": {
                  "type": "number"
                }
              },
              "required": ["time", "value"],
              "additionalProperties": false
            }
          }
        },
        "required": ["kind", "target", "name", "value", "trackId", "tool", "toolId", "clipId", "parameter", "setting", "start", "end", "rate", "events"],
        "allOf": [
          {
            "if": {
              "properties": {
                "kind": { "const": "automation" }
              },
              "required": ["kind"]
            },
            "then": {
              "required": ["points"]
            }
          }
        ],
        "additionalProperties": false
      }
    }
  },
  "required": ["summary", "musicalPlan", "actions"],
  "additionalProperties": false
}
